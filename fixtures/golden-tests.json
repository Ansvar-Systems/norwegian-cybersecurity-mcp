    },
    {
      "id": "no-cyber-014",
      "category": "search",
      "description": "Search guidance for 'hendelseshandtering' (incident response)",
      "tool": "no_cyber_search_guidance",
      "input": { "query": "hendelseshandtering" },
      "assertions": { "result_not_empty": true }
